{
  "name": "my-player-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npx next dev",
    "build:frontend": "cd frontend && npx next build",
    "start:frontend": "cd frontend && npx next start",
    "dev:backend": "npx ts-node-dev --respawn --transpile-only --project tsconfig.server.json backend/src/main.ts",
    "build:backend": "tsc -p tsconfig.server.json",
    "start:backend": "node backend/dist/main.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "axios": "^1.18.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^4.18.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^4.10.1",
    "react-player": "^3.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5"
  }
}
